#!/usr/bin/env bash
# productune-lite — daily entrypoint.
#   productune-lite            init the cwd as a lite project (if needed), then launch the PO
#   productune-lite install    (re)run the installer
#   productune-lite --help
#
# Launches `claude --agent pdtl-po` in the foreground. The SessionStart hook injects
# the PO doctrine + this project's memory/state. No worktree split, no engine flags,
# no statusline — lite keeps the entrypoint thin.

set -euo pipefail

HOME_ROOT="$HOME/.productune-lite"
[ -f "$HOME_ROOT/productune-lite.env" ] && . "$HOME_ROOT/productune-lite.env"

say() { printf '\033[36m[productune-lite]\033[0m %s\n' "$*"; }

# ---------------------------------------------------------------------------
# trust_accept — idempotently mark THIS project trusted in ~/.claude.json so the
# launch never stalls on the trust dialog. Runs EVERY launch (cheap, self-heals).
# Hard rule: NEVER block launch — every failure path is silent (|| true / skip).
# ---------------------------------------------------------------------------
_pdtl_trust_accept() {
  local proj="$1"
  [ -n "$proj" ] || return 0                       # need an abs project path
  command -v jq >/dev/null 2>&1 || return 0         # jq missing → skip silently

  local cj="$HOME/.claude.json"
  [ -e "$cj" ] || printf '{}\n' > "$cj" 2>/dev/null || return 0

  # Parse-check: if ~/.claude.json isn't valid JSON, leave it untouched.
  jq -e . "$cj" >/dev/null 2>&1 || return 0

  # Already trusted? then nothing to write (avoids needless churn + backups).
  local already
  already="$(jq -r --arg p "$proj" '.projects[$p].hasTrustDialogAccepted // false' "$cj" 2>/dev/null)" || return 0
  [ "$already" = "true" ] && return 0

  # One-time backup before the first mutating write (skip if any bak already exists).
  local have_bak=""
  for b in "$HOME_ROOT"/.claude.json.bak.*; do
    [ -e "$b" ] && { have_bak=1; break; }
  done
  [ -n "$have_bak" ] || cp "$cj" "$HOME_ROOT/.claude.json.bak.$(date -u +%Y%m%dT%H%M%SZ 2>/dev/null || echo backup)" 2>/dev/null || true

  # Atomic write (tmp + mv), preserving every existing key.
  local tmp
  tmp="$(mktemp 2>/dev/null)" || return 0
  if jq --arg p "$proj" '
        .projects //= {} |
        .projects[$p] //= {} |
        .projects[$p].hasTrustDialogAccepted = true
      ' "$cj" > "$tmp" 2>/dev/null && [ -s "$tmp" ]; then
    mv "$tmp" "$cj" 2>/dev/null || rm -f "$tmp" 2>/dev/null
  else
    rm -f "$tmp" 2>/dev/null
  fi
  return 0
}

# ---------------------------------------------------------------------------
# auto_update — pull if: clean + tracking + behind + ff-only. Never fatal.
# ---------------------------------------------------------------------------
_pdtl_autoupdate() {
  local repo="${PDTL_REPO:-}"
  # Need a known repo path.
  [ -n "$repo" ] && [ -d "$repo/.git" ] || return 0

  # Throttle: once per day via timestamp file.
  local stamp_file="$HOME_ROOT/.last-autoupdate"
  local today
  today="$(date -u +%Y-%m-%d 2>/dev/null)" || return 0
  if [ -f "$stamp_file" ]; then
    local last
    last="$(cat "$stamp_file" 2>/dev/null)"
    [ "$last" = "$today" ] && return 0
  fi

  # All git checks run with || return 0 so any failure silently skips.
  command -v git >/dev/null 2>&1 || return 0

  # Repo must not be dirty (untracked files OK, only tracked changes matter).
  git -C "$repo" diff --quiet HEAD 2>/dev/null || return 0

  # Must be on a branch (not detached HEAD).
  local branch
  branch="$(git -C "$repo" symbolic-ref --short HEAD 2>/dev/null)" || return 0

  # Branch must track an upstream.
  local upstream
  upstream="$(git -C "$repo" rev-parse --abbrev-ref "@{upstream}" 2>/dev/null)" || return 0

  # Fetch quietly (network failure → skip).
  git -C "$repo" fetch --quiet 2>/dev/null || return 0

  # Must be behind (HEAD != upstream tip).
  local local_sha upstream_sha
  local_sha="$(git -C "$repo" rev-parse HEAD 2>/dev/null)" || return 0
  upstream_sha="$(git -C "$repo" rev-parse "$upstream" 2>/dev/null)" || return 0
  [ "$local_sha" != "$upstream_sha" ] || { printf '%s\n' "$today" > "$stamp_file"; return 0; }

  # Must be ff-only (upstream must be ahead, not diverged).
  local base
  base="$(git -C "$repo" merge-base HEAD "$upstream" 2>/dev/null)" || return 0
  [ "$base" = "$local_sha" ] || return 0

  # All clear — pull.
  say "auto-update: pulling $branch …"
  git -C "$repo" pull --ff-only --quiet 2>/dev/null || return 0
  say "auto-update: re-running installer …"
  bash "$repo/scripts/install.sh" 2>/dev/null || return 0
  say "auto-update: done."

  printf '%s\n' "$today" > "$stamp_file" || true
}

case "${1:-}" in
  install)
    exec bash "${PDTL_REPO:?run install.sh once first}/scripts/install.sh"
    ;;
  -h|--help)
    cat <<'EOF'
productune-lite — a lightweight PO-driven product workflow for planners.

  productune-lite            init this directory as a lite project (first run) and
                             launch the PO (claude --agent pdtl-po)
  productune-lite install    (re)run the installer (mirror doctrine, link agents, hook, PATH)
  productune-lite --help     this help

Lifecycle (PO-judged, no gates): Define -> Build -> Ship.
Memory: docs/memory.md (single curated file). State: .productune-lite/po-state.json.
EOF
    exit 0
    ;;
esac

# Auto-update (default launch path only; opt-out via PDTL_NO_AUTOUPDATE=1).
if [ "${PDTL_NO_AUTOUPDATE:-0}" != "1" ]; then
  _pdtl_autoupdate
fi

PROJ="$PWD"

# Auto-accept the trust dialog for this project so launch never stalls.
# Runs on every launch (first-run AND already-init'd); never blocks.
_pdtl_trust_accept "$PROJ"

# First run in this directory → scaffold the lite project (tiny footprint).
if [ ! -d "$PROJ/.productune-lite" ]; then
  say "initializing lite project in $PROJ"
  mkdir -p "$PROJ/.productune-lite" "$PROJ/docs/prd" "$PROJ/docs/artifacts" "$PROJ/briefs"

  SLUG="$(basename "$PROJ")"
  NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  cat > "$PROJ/.productune-lite/config.json" <<EOF
{ "slug": "$SLUG", "created_at": "$NOW", "tool": "productune-lite" }
EOF
  cat > "$PROJ/.productune-lite/po-state.json" <<'EOF'
{ "schema_version": 1, "stage": "define", "version": "v1", "current_task": null }
EOF
  [ -f "$PROJ/docs/memory.md" ] || cat > "$PROJ/docs/memory.md" <<'EOF'
# Project memory

> Curated by the PO. One fact per line, dated. Replaces all tier-memory machinery.

## Decisions

## Preferences

## Project facts

## Learnings
EOF
  [ -f "$PROJ/docs/prd/PRD.md" ] || printf '# PRD\n\n_(empty — the PO + designer fill this during Define.)_\n' > "$PROJ/docs/prd/PRD.md"
  say "scaffolded .productune-lite/, docs/memory.md, docs/prd/PRD.md"
fi

# Guard: doctrine must be mirrored.
if [ ! -f "$HOME_ROOT/doctrine/po/habit.md" ]; then
  say "doctrine not installed yet — run: productune-lite install"
  exit 1
fi

command -v claude >/dev/null 2>&1 || { say "'claude' CLI not found — npm i -g @anthropic-ai/claude-code"; exit 1; }

say "launching PO …"
exec claude --add-dir "$HOME_ROOT" --agent pdtl-po
